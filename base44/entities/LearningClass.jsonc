{
  "name": "LearningClass",
  "type": "object",
  "description": "Educational class/course in the Learning Center. Designed for beginner-friendly education with multiple literacy levels.",
  "properties": {
    "track_id": {
      "type": "string",
      "description": "LearningTrack.track_id this class belongs to (e.g. track_01)"
    },
    "order": {
      "type": "integer",
      "description": "Sort order within the track"
    },
    "category": {
      "type": "string",
      "enum": [
        "orientation",
        "employment",
        "housing",
        "financial_literacy",
        "digital_literacy",
        "ai_literacy",
        "life_skills",
        "wellness",
        "documentation"
      ],
      "description": "Major category of learning"
    },
    "title": {
      "type": "string",
      "description": "Class title (plain language, beginner-friendly)"
    },
    "description": {
      "type": "string",
      "description": "Short description (2-3 sentences, plain language)"
    },
    "estimated_minutes": {
      "type": "number",
      "description": "Estimated time to complete (in minutes)"
    },
    "difficulty": {
      "type": "string",
      "enum": [
        "beginner",
        "intermediate",
        "advanced"
      ],
      "default": "beginner"
    },
    "target_populations": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "reentry",
          "recovery",
          "veteran",
          "homeless",
          "at_risk",
          "all"
        ]
      }
    },
    "completion_required": {
      "type": "boolean",
      "default": true
    },
    "prerequisites": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Array of class IDs that must be completed first"
    },
    "learning_objectives": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "What learner will be able to do after completing"
    },
    "youtube_url": {
      "type": "string"
    },
    "youtube_search_phrase": {
      "type": "string"
    },
    "additional_videos": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "url": {
            "type": "string"
          }
        }
      }
    },
    "difficulty_level": {
      "type": "string",
      "enum": [
        "beginner",
        "basic",
        "intermediate"
      ],
      "default": "beginner"
    },
    "literacy_level_support": {
      "type": "string",
      "enum": [
        "low",
        "standard"
      ]
    },
    "passing_score": {
      "type": "number",
      "default": 70
    },
    "is_required": {
      "type": "boolean",
      "default": false
    },
    "is_active": {
      "type": "boolean",
      "default": true
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "published",
        "archived"
      ],
      "default": "draft"
    },
    "reflection_prompt": {
      "type": "string"
    },
    "content_outline": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "section_title": {
            "type": "string"
          },
          "key_points": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "quiz_questions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "question": {
            "type": "string"
          },
          "options": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "correct_answer": {
            "type": "string"
          },
          "explanation": {
            "type": "string"
          }
        }
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "created_by": {
      "type": "string"
    },
    "organization_id": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "category",
    "description"
  ],
  "rls": {
    "create": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "role": "staff"
          }
        }
      ]
    },
    "read": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "role": "staff"
          }
        },
        {
          "user_condition": {
            "role": "resident"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "role": "staff"
          }
        }
      ]
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}